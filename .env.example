# ──────────────────────────────────────────────────────────────────
# Einlich ShirtForm — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────

# MongoDB connection string (external server)
MONGODB_URI=mongodb://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:27017/

# Secret used to sign JWT tokens for the Reports section
# Generate a strong random value, e.g.:  openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_secret

# Password required to access the /reportes page
REPORTS_PASSWORD=change_me_to_a_secure_password

# Allowed CORS origins for the backend (comma-separated, or * for all)
# In production, set this to your frontend's public URL.
CORS_ORIGIN=*

# Port the frontend nginx container listens on (default 80)
FRONTEND_PORT=80
